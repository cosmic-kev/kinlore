{
  "name": "kinlore",
  "version": "0.2.2",
  "description": "Family photo tagging tool — desktop app",
  "main": "main.js",
  "author": "cosmic-kev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cosmic-kev/kinlore.git"
  },
  "scripts": {
    "start": "node launch.js",
    "build": "node build.js"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.cosmickev.kinlore",
    "productName": "Kinlore",
    "files": [
      "kinlore.html",
      "main.js",
      "preload.js"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "cosmic-kev",
        "repo": "kinlore",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Kinlore"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
